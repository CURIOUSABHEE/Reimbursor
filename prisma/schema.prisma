generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  expenses          Expense[]
  approvalWorkflows ApprovalWorkflow[]
  approvalRules     ApprovalRule[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(EMPLOYEE)
  companyId String
  managerId String?
  company   Company  @relation(fields: [companyId], references: [id])
  manager   User?    @relation("UserManager", fields: [managerId], references: [id])
  reports   User[]   @relation("UserManager")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses           Expense[]              @relation("EmployeeExpenses")
  approvalActions    ApprovalAction[]       @relation("ApproverActions")
  notifications      Notification[]
  overriddenExpenses Expense[]              @relation("AdminOverrides")
  sendPasswordTokens SendPasswordToken[]
  approvalSteps      ApprovalStep[]         @relation("StepApprover")
  sentMessages       ChatMessage[]          @relation("SentMessages")
  receivedMessages   ChatMessage[]          @relation("ReceivedMessages")
  assignedRules      ApprovalRule[]         @relation("AssignedRules")
  managedRules       ApprovalRule[]         @relation("ManagedRules")
  ruleApprovers      ApprovalRuleApprover[] @relation("RuleApprovers")

  @@unique([email, companyId])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

model Expense {
  id                  String          @id @default(cuid())
  description         String
  category            ExpenseCategory
  date                DateTime
  submittedAmount     Decimal         @db.Decimal(10, 2)
  submittedCurrency   String
  convertedAmount     Decimal         @db.Decimal(10, 2)
  exchangeRate        Decimal         @default(1) @db.Decimal(10, 6)
  status              ExpenseStatus   @default(DRAFT)
  currentWorkflowStep Int             @default(0)
  companyId           String
  company             Company         @relation(fields: [companyId], references: [id])
  employeeId          String
  employee            User            @relation("EmployeeExpenses", fields: [employeeId], references: [id])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  idempotencyKey      String?         @unique

  isAdminOverride      Boolean   @default(false)
  adminOverrideById    String?
  adminOverrideBy      User?     @relation("AdminOverrides", fields: [adminOverrideById], references: [id])
  adminOverrideAt      DateTime?
  adminOverrideComment String?

  approvalActions ApprovalAction[]
  receipt         Receipt?
  notifications   Notification[]
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  ACCOMMODATION
  TRANSPORTATION
  SUPPLIES
  EQUIPMENT
  OTHER
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model ApprovalWorkflow {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps ApprovalStep[]

  @@unique([companyId, name])
}

model ApprovalStep {
  id                 String           @id @default(cuid())
  workflowId         String
  workflow           ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder          Int
  name               String
  approverIds        String[]         @default([])
  type               StepType         @default(SEQUENTIAL)
  minApprovalPercent Int              @default(100)
  specificApproverId String?
  specificApprover   User?            @relation("StepApprover", fields: [specificApproverId], references: [id])
  approverRole       Role?
  autoComplete       Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  approvalActions ApprovalAction[]

  @@unique([workflowId, stepOrder])
  @@index([workflowId, stepOrder])
}

enum StepType {
  SEQUENTIAL
  PARALLEL
  ANY_ONE
}

model ApprovalRule {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id])
  name                  String
  description           String?
  assignedUserId        String?
  assignedUser          User?    @relation("AssignedRules", fields: [assignedUserId], references: [id])
  managerId             String?
  manager               User?    @relation("ManagedRules", fields: [managerId], references: [id])
  isManagerApprover     Boolean  @default(false)
  approversSequence     Boolean  @default(false)
  minApprovalPercentage Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  approvers       ApprovalRuleApprover[]
  approvalActions ApprovalAction[]
}

model ApprovalRuleApprover {
  id        String       @id @default(cuid())
  ruleId    String
  rule      ApprovalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation("RuleApprovers", fields: [userId], references: [id])
  stepOrder Int
  required  Boolean      @default(false)
}

model ApprovalAction {
  id             String        @id @default(cuid())
  expenseId      String
  expense        Expense       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  stepId         String?
  step           ApprovalStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)
  approverId     String
  approver       User          @relation("ApproverActions", fields: [approverId], references: [id])
  action         ActionStatus  @default(PENDING)
  stepOrder      Int
  comment        String?
  actedAt        DateTime?
  idempotencyKey String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  ruleId String?
  rule   ApprovalRule? @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([expenseId, stepOrder, approverId])
  @@index([approverId, action])
  @@index([expenseId, action])
}

enum ActionStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

model Receipt {
  id        String   @id @default(cuid())
  expenseId String   @unique
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  expenseId      String?
  expense        Expense?         @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  type           NotificationType @default(INFO)
  title          String
  message        String
  read           Boolean          @default(false)
  metadata       Json?
  idempotencyKey String?          @unique
  createdAt      DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum NotificationType {
  INFO
  EXPENSE_SUBMITTED
  APPROVAL_REQUIRED
  APPROVAL_ACTION
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  SYSTEM
  STEP_ACTIVATED
  STEP_COMPLETED
}

model SendPasswordToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model ChatMessage {
  id         String   @id @default(cuid())
  companyId  String
  senderId   String
  receiverId String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}
